# GlimOko Environment Configuration

# GitHub App ID (found in App settings)
APP_ID=

# GitHub App Private Key (content of the .pem file, wrapped in quotes)
# PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
PRIVATE_KEY=

# Webhook Secret (defined in App settings)
WEBHOOK_SECRET=

# Server Port
PORT=3000
